#!/bin/bash
# wifi-menu.sh — nmcli + yad wifi manager for i3

# Scan for networks
notify-send "WiFi" "Scanning..." -t 1500 2>/dev/null
nmcli device wifi rescan 2>/dev/null
#sleep 1

# Get saved connection SSIDs
saved=$(nmcli -t -f NAME connection show | tr '\n' '|')
saved+="|"

# Build network list for yad (SSID, Signal, Security, Saved)
network_list=$(nmcli -t -f SSID,SIGNAL,SECURITY device wifi list | \
    awk -F: '
    NF>=2 && $1 != "" {
        ssid=$1
        signal=$2
        security=$3
        print ssid"\n"signal"\n"security
    }
    ' | paste - - - | sort -t$'\t' -k2 -rn | \
    while IFS=$'\t' read -r ssid signal security; do
        # Mark saved networks
        if echo "$saved" | grep -qF "$ssid|"; then
            saved_mark="yes"
        else
            saved_mark="no"
        fi
        echo "$ssid"
        echo "$signal%"
        echo "${security:-Open}"
        echo "$saved_mark"
    done)

# Show network picker
selected=$(echo "$network_list" | \
    yad --list \
        --title="WiFi Networks" \
        --column="SSID" \
        --column="Signal" \
        --column="Security" \
        --column="Saved" \
        --width=420 --height=450 \
        --print-column=1 \
        --separator="\n" \
        --button="Connect:0" \
        --button="Disconnect:2" \
        --button="Cancel:1" \
        2>/dev/null)

exit_code=$?
ssid=$(echo "$selected" | head -1 | tr -d '|')

# Cancel
[[ $exit_code -eq 1 || -z "$ssid" ]] && exit 0

# Disconnect
if [[ $exit_code -eq 2 ]]; then
    active=$(nmcli -t -f NAME,DEVICE connection show --active | grep wifi | cut -d: -f1)
    if [[ -n "$active" ]]; then
        nmcli connection down "$active" && \
            notify-send "WiFi" "Disconnected from $active" 2>/dev/null
    fi
    exit 0
fi

# Connect — check if already saved
#
if echo "$saved" | grep -qF "$ssid|"; then
    # Saved — connect directly
    result=$(nmcli connection up "$ssid" 2>&1)
else
    # Check if open network
    security=$(nmcli -t -f SSID,SECURITY device wifi list | \
        grep "^${ssid}:" | cut -d: -f2)

    if [[ -z "$security" || "$security" == "--" ]]; then
        # Open network
        result=$(nmcli device wifi connect "$ssid" 2>&1)
    else
        # Ask for password
        password=$(yad --entry \
            --title="WiFi Password" \
            --text="Password for <b>$ssid</b>:" \
            --hide-text \
            --width=320 \
            --button="Connect:0" \
            --button="Cancel:1" \
            2>/dev/null)

        [[ $? -ne 0 || -z "$password" ]] && exit 0
        result=$(nmcli device wifi connect "$ssid" password "$password" 2>&1)
    fi
fi

# Notify result
if echo "$result" | grep -q "successfully"; then
    notify-send "WiFi" "Connected to $ssid" -i network-wireless 2>/dev/null
else
    notify-send "WiFi" "Failed: $result" -u critical 2>/dev/null
fi
